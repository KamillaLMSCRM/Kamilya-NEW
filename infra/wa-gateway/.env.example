# wa-gateway environment

# Kamilya backend JWT secret — shared with apps/api on Render.
# Generate: openssl rand -hex 32
# Must match KAMILYA_BACKEND_SECRET in Render env.
KAMILYA_BACKEND_SECRET=__REPLACE_ME__

# Port for wa-gateway (matches nginx proxy_pass upstream)
PORT=8700

# Bind address — 127.0.0.1 only (nginx proxies external traffic)
HOST=127.0.0.1

# Directory for per-tenant WhatsApp session files (creds.json, app-state)
# Persistent — survives restarts. Make sure this is on a non-ephemeral disk.
SESSIONS_DIR=./sessions

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Mock mode — when true, sessions don't connect to WhatsApp servers.
# Useful for local dev / testing the API surface without a real number.
# NEVER set in production.
MOCK_MODE=false

# Health-check bind for monitoring
# (same as PORT/HOST — kept here for systemd/PM2 compatibility)